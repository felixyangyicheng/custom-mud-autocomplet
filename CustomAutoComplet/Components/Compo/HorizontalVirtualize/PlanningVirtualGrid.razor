@typeparam TItem
@typeparam TEvent

<style>
    .layout {
        display: flex;
        border: 1px solid #ccc;
        height: 400px;
    }

    .left {
        width: 180px;
        flex-shrink: 0;
        border-right: 1px solid #ccc;
        background: #f5f5f5;
    }

    .row-label {
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 10px;
        border-bottom: 1px solid #ddd;
    }

    .right {
        overflow-x: auto;
        flex: 1;
    }

    .grid {
        display: flex;
    }

    .column {
        width: 120px;
        flex-shrink: 0;
    }

    .cell {
        height: 60px;
        border: 1px solid #eee;
        position: relative;
    }

    .event {
        position: absolute;
        width: 100%;
        background: #1976d2;
        opacity: 0.85;
        cursor: grab;
    }
</style>

<div class="layout">

    <!-- 左列 -->
    <div class="left">
        @foreach (var row in Rows)
        {
            <div class="row-label">@RowLabel(row)</div>
        }
    </div>

    <!-- 右侧 -->
    <div class="right" @ref="ScrollRef" @onscroll="OnScroll">

        <div class="grid" style="width:@(TotalWidth)px">

            <div style="width:@(StartIndex* ColumnWidth)px"></div>

            @foreach (var date in VisibleDates)
            {
                <div class="column">

                    @foreach (var row in Rows)
                    {
                        <div class="cell"
                             @ref="cellRefs[(RowId(row), date)]"
                             @ondragover:preventDefault
                             @ondrop="e => OnDrop(e, row, date)">

                            @foreach (var ev in GetEvents(row, date))
                            {
                                <div class="event"
                                     draggable="true"
                                     @ondragstart="() => OnDragStart(ev)"
                                     style="
                                                    height:@GetHeight(ev)%;
                                                    bottom:@GetBottom(ev)%;">
                                </div>
                            }
                        </div>
                    }

                </div>
            }

            <div style="width:@((Dates.Count - EndIndex) * ColumnWidth)px"></div>

        </div>

    </div>

</div>

@code {

    // ===== 参数 =====

    [Parameter] public List<TItem> Rows { get; set; } = new();
    [Parameter] public List<DateTime> Dates { get; set; } = new();
    [Parameter] public List<TEvent> Events { get; set; } = new();

    [Parameter] public Func<TItem, string> RowLabel { get; set; } = default!;
    [Parameter] public Func<TItem, int> RowId { get; set; } = default!;

    [Parameter] public Func<TEvent, int> GetEventRowId { get; set; } = default!;
    [Parameter] public Func<TEvent, DateTime> GetEventDate { get; set; } = default!;
    [Parameter] public Func<TEvent, TimeSpan> GetStart { get; set; } = default!;
    [Parameter] public Func<TEvent, TimeSpan> GetEnd { get; set; } = default!;

    [Parameter] public Action<TEvent, int, DateTime, TimeSpan, TimeSpan> OnEventChanged { get; set; } = default!;

    // ===== 虚拟化 =====

    const int ColumnWidth = 120;
    const int Buffer = 3;

    ElementReference ScrollRef;

    int StartIndex = 0;
    int EndIndex = 10;

    List<DateTime> VisibleDates =>
        Dates.Skip(StartIndex).Take(EndIndex - StartIndex).ToList();

    int TotalWidth => Dates.Count * ColumnWidth;

    async Task OnScroll()
    {
        var scrollLeft = await JS.InvokeAsync<double>("getScrollLeft", ScrollRef);
        var width = await JS.InvokeAsync<double>("getClientWidth", ScrollRef);

        int first = (int)(scrollLeft / ColumnWidth);
        int count = (int)(width / ColumnWidth);

        StartIndex = Math.Max(0, first - Buffer);
        EndIndex = Math.Min(Dates.Count, first + count + Buffer);

        StateHasChanged();
    }

    // ===== 拖拽 =====

    static TEvent? DraggingEvent;

    void OnDragStart(TEvent ev)
    {
        DraggingEvent = ev;
    }

    async Task OnDrop(DragEventArgs e, TItem row, DateTime date)
    {
        if (DraggingEvent == null) return;

        var rect = await JS.InvokeAsync<ElementRect>("getElementRect", cellRefs[(RowId(row), date)]);

        var percent = Math.Clamp((e.ClientY - rect.Top) / rect.Height, 0, 1);

        var duration = GetEnd(DraggingEvent) - GetStart(DraggingEvent);

        var startHour = 9 + percent * 8;

        var newStart = TimeSpan.FromHours(Math.Floor(startHour));
        var newEnd = newStart + duration;

        OnEventChanged.Invoke(
            DraggingEvent,
            RowId(row),
            date,
            newStart,
            newEnd
        );

        DraggingEvent = default;

        StateHasChanged();
    }

    // ===== 工具 =====

    Dictionary<(int, DateTime), ElementReference> cellRefs = new();

    IEnumerable<TEvent> GetEvents(TItem row, DateTime date)
    {
        return Events.Where(e =>
            GetEventDate(e).Date == date.Date &&
            GetEventRowId(e) == RowId(row));
    }

    double GetHeight(TEvent ev)
        => ((GetEnd(ev) - GetStart(ev)).TotalHours / 8.0) * 100;

    double GetBottom(TEvent ev)
        => ((GetStart(ev).TotalHours - 9) / 8.0) * 100;

    [Inject] IJSRuntime JS { get; set; }

    public class ElementRect
    {
        public double Top { get; set; }
        public double Height { get; set; }
    }
}